{
  "name": "@stbr/sss-token",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Solana Stablecoin Standard (SSS-1 and SSS-2)",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "tsc --noEmit",
    "test": "echo \"No tests yet\"",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "solana",
    "stablecoin",
    "anchor",
    "token-2022",
    "sss"
  ],
  "license": "MIT",
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/spl-token": "^0.4.0",
    "@solana/web3.js": "^1.95.0"
  },
  "devDependencies": {
    "@types/bn.js": "^5.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
